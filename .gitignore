# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# Materialised PokerBench prompt SQL sandbox (regenerable from parquet mirror
# or raw PokerBench via `scripts/spin_up_prompt_sandbox.sh`).
data/pokerbench_prompts.sqlite
data/pokerbench_prompts.sqlite-journal

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site (root-only; do not shadow poker/docs/ or other in-tree docs dirs)
/docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# applications/slack — ignore everything under this directory at any depth.
# Patterns apply to any matching path Git may see later; files need not exist
# when this rule is written. Only README.md stays eligible for commits.
# Note: paths already tracked by Git remain tracked until removed from the index.
applications/slack/*
applications/slack/**
!applications/slack/README.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
build/
dist/

# Notebooks
.ipynb_checkpoints/

# ML artifacts / large data
data/raw/
data/interim/
data/processed/
artifacts/
outputs/
runs/
wandb/
trackio/
*.ckpt
*.pt
*.pth
*.bin
*.safetensors
*.gguf
*.joblib
!poker_predictor/**/*.joblib

